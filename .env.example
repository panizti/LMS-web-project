# ═══════════════════════════════════════════════════════════════
#  فایل تنظیمات محیطی بک‌اند LMS
#  این فایل را به نام .env کپی کنید و مقادیر را تنظیم کنید
# ═══════════════════════════════════════════════════════════════

# ─── اتصال به MongoDB ────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/lms_db

# ─── تنظیمات JWT ─────────────────────────────────────────────
# ⚠️ حتماً این مقدار را در محیط production عوض کنید!
JWT_SECRET=my_super_secret_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=1d

# ─── تنظیمات سرور (اختیاری) ─────────────────────────────────
PORT=4000

# ─── CORS ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
