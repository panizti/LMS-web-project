# ═══════════════════════════════════════════════════════════════
#  فایل تنظیمات محیطی بک‌اند LMS
#  این فایل در .gitignore است و باید local ساخته شود
# ═══════════════════════════════════════════════════════════════

# ─── اتصال به MongoDB ────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/lms_db

# ─── تنظیمات JWT ─────────────────────────────────────────────
JWT_SECRET=my_super_secret_key_change_this_in_production_min_32_chars_long
JWT_EXPIRES_IN=1d

# ─── تنظیمات سرور (اختیاری) ─────────────────────────────────
PORT=4000

# ─── CORS ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
